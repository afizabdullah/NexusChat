# ═══════════════════════════════════════════════════════════
node_modules/
package.json
package-lock.json
pnpm-lock.yaml
pnpm-workspace.yaml
yarn.lock
.npmrc
tsconfig*.json

# ═══════════════════════════════════════════════════════════
# TEMPORARY/EXTERNAL LIBRARIES
# ═══════════════════════════════════════════════════════════
lib/
scripts/
webrtc-android-main/

# ═══════════════════════════════════════════════════════════
# ANDROID / KOTLIN PROJECT
# ═══════════════════════════════════════════════════════════

# Gradle files
.gradle/
build/
app/build/
*/build/
**/build/

# Local configuration file (sdk path, etc)
local.properties

# Log/OS Files
*.log

# Android Studio generated files and folders
captures/
.externalNativeBuild/
.cxx/
*.apk
*.aab
output.json

# IntelliJ IDEA
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml

# Keystore files (NEVER commit these!)
*.jks
*.keystore

# Android Profiling
*.hprof

# Kotlin
.kotlin/

# Build outputs
*.class
*.dex
*.ap_

# Temporary files
*.swp
*.bak
*~

# ═══════════════════════════════════════════════════════════
