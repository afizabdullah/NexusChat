{
  "rules": {
    // Users node
    "users": {
      "$userId": {
        // Anyone authenticated can read user profiles
        ".read": "auth != null",
        
        // Only the user can write their own profile
        ".write": "auth != null && auth.uid === $userId",
        
        // Validate user data structure (only on create, flexible for updates)
        ".validate": "!data.exists() ? newData.hasChildren(['username', 'email']) : true"
      }
    },
    
    // Stories node
    "stories": {
      // Anyone authenticated can read stories
      ".read": "auth != null",
      
      "$storyId": {
        // Only authenticated users can create stories
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
        
        // Validate story data structure — only on create
        ".validate": "!data.exists() ? newData.hasChildren(['userId', 'timestamp', 'expiresAt']) : true"
      }
    },
    
    // Chats node — members can be stored as array or map
    "chats": {
      "$chatId": {
        // Members can read/write their chats
        // Uses hasChild (for map storage: {uid: true}) OR contains (for array storage: [uid1, uid2])
        ".read": "auth != null && (!data.exists() || data.child('members').hasChild(auth.uid) || data.child('members').val().toString().contains(auth.uid))",
        
        ".write": "auth != null && (!data.exists() || data.child('members').hasChild(auth.uid) || data.child('members').val().toString().contains(auth.uid))",
        
        // Messages in chat
        "messages": {
          "$messageId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    
    // Typing indicators
    "typing": {
      "$chatId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && auth.uid === $userId"
        }
      }
    },
    
    // AI Chats
    "aiChats": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    
    // Story replies
    "storyReplies": {
      "$storyOwnerId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    
    // Friend requests node
    "friendRequests": {
      "$requestId": {
        // Users can read requests sent to them or by them
        ".read": "auth != null && (!data.exists() || data.child('fromUserId').val() === auth.uid || data.child('toUserId').val() === auth.uid)",
        
        // Users can create/update friend requests
        ".write": "auth != null && (!data.exists() || data.child('fromUserId').val() === auth.uid || data.child('toUserId').val() === auth.uid)"
      }
    },
    
    // Calls node
    "calls": {
      "$callId": {
        // Participants can read call data
        ".read": "auth != null && (!data.exists() || data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)",
        
        // Participants can write call data
        ".write": "auth != null && (!data.exists() || data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)"
      }
    }
  }
}
